{%- comment -%}
  ============================================================
  TRUST BADGES SECTION — grünes Band unter der PDP
  ============================================================
  6 feste Badges (Icon + Label) gemäß Figma, OHNE Schema-Blocks
  (das neue Dawn ist bei lokalen Blocks streng -> bewusst fest gerendert).
  Texte/Icons unten in den beiden Listen anpassbar, Farben in den CSS-Variablen.

  Einbindung: Datei nach  sections/trust-badges.liquid
{%- endcomment -%}

{%- assign tb_icons  = "shield,lab,dna,leaf,droplet,factory" | split: "," -%}
{%- assign tb_labels = "Omega-Schutz,Laborzertifiziert,Gentechnikfrei,Vegan,Omega-3-reich,Herstellung in Deutschland" | split: "," -%}

<section class="tb" id="tb-{{ section.id }}">
  <div class="tb__inner">
    {%- for icon in tb_icons -%}
      <div class="tb__item">
        <span class="tb__icon">
          {%- case icon -%}
            {%- when 'shield' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9 12l2 2 4-4"/></svg>
            {%- when 'lab' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M9 3h6M10 3v6l-4.5 8a2 2 0 0 0 1.8 3h9.4a2 2 0 0 0 1.8-3L14 9V3"/><path d="M8 15h8"/></svg>
            {%- when 'dna' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M7 3c0 5 10 5 10 10S7 18 7 21M17 3c0 5-10 5-10 10s10 5 10 8"/><path d="M8.5 6h7M8.5 18h7M9.5 9h5M9.5 15h5"/></svg>
            {%- when 'leaf' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M5 19c8 0 14-5 14-14C9 5 5 11 5 19z"/><path d="M5 19c2-4 5-7 9-9"/></svg>
            {%- when 'droplet' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M12 3s6 6.5 6 11a6 6 0 0 1-12 0c0-4.5 6-11 6-11z"/></svg>
            {%- when 'factory' -%}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4"><path d="M3 21V10l5 3V10l5 3V8l5 3v10z"/><path d="M3 21h18"/></svg>
          {%- endcase -%}
        </span>
        <span class="tb__label">{{ tb_labels[forloop.index0] }}</span>
      </div>
    {%- endfor -%}
  </div>
</section>

<style>
  #tb-{{ section.id }} {
    --tb-band: #E8EFE4;     /* helles Grün (aus Figma anpassen) */
    --tb-green: #557A52;    /* Icon-Farbe */
    --tb-text: #2b2b2b;
    background: var(--tb-band);
    padding: 28px 0;
    font-family: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
  }
  #tb-{{ section.id }} .tb__inner {
    max-width: 1280px; margin: 0 auto; padding: 0 24px;
    display: grid; grid-template-columns: repeat(6, 1fr); gap: 16px;
  }
  #tb-{{ section.id }} .tb__item { display: flex; flex-direction: column; align-items: center; text-align: center; gap: 10px; }
  #tb-{{ section.id }} .tb__icon {
    width: 56px; height: 56px; border-radius: 50%; background: #fff;
    display: inline-flex; align-items: center; justify-content: center; color: var(--tb-green);
  }
  #tb-{{ section.id }} .tb__icon svg { width: 28px; height: 28px; }
  #tb-{{ section.id }} .tb__label { font-size: 13px; color: var(--tb-text); line-height: 1.3; max-width: 120px; }

  @media (max-width: 749px) {
    #tb-{{ section.id }} { padding: 22px 0; }
    #tb-{{ section.id }} .tb__inner {
      grid-template-columns: repeat(3, 1fr); gap: 22px 12px; padding: 0 18px;
    }
  }
</style>

{% schema %}
{
  "name": "Trust Badges",
  "tag": "section",
  "class": "section-trust-badges",
  "settings": [],
  "presets": [
    { "name": "Trust Badges" }
  ]
}
{% endschema %}
