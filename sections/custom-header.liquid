{%- assign menu = section.settings.menu -%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap" rel="stylesheet">

<header class="ch{% if section.settings.enable_sticky %} ch--sticky{% endif %}" id="ch-{{ section.id }}">
  <div class="ch__inner">

    <div class="ch__left">
      <button type="button" class="ch__burger" aria-label="Menü öffnen" aria-expanded="false" data-burger>
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M3 6h18M3 12h18M3 18h18"/></svg>
      </button>
      <nav class="ch__nav" aria-label="Hauptnavigation">
        {%- if menu != blank -%}
          {%- for link in menu.links -%}
            <a href="{{ link.url }}" class="ch__link">{{ link.title }}</a>
          {%- endfor -%}
        {%- else -%}
          <a href="#" class="ch__link">Shop</a>
          <a href="#" class="ch__link">Rezepte</a>
          <a href="#" class="ch__link">Über uns</a>
        {%- endif -%}
      </nav>
    </div>

    <div class="ch__center">
      <a href="{{ routes.root_url }}" class="ch__logo" aria-label="{{ shop.name | escape }}">
        {%- if section.settings.logo != blank -%}
          {%- assign logo_height = section.settings.logo_width | times: section.settings.logo.height | divided_by: section.settings.logo.width -%}
          <img
            src="{{ section.settings.logo | image_url: width: 200 }}"
            alt="{{ shop.name | escape }}"
            width="{{ section.settings.logo_width }}"
            height="{{ logo_height }}"
            style="width: {{ section.settings.logo_width }}px; height: auto;">
        {%- else -%}
          <span class="ch__logo-text">{{ shop.name }}</span>
        {%- endif -%}
      </a>
    </div>

    <div class="ch__right">
      {%- if section.settings.show_account -%}
        <a href="{{ routes.account_url }}" class="ch__icon" aria-label="Konto">
          <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5"><circle cx="12" cy="8" r="3.5"/><path d="M5 20c0-3.5 3-6 7-6s7 2.5 7 6"/></svg>
        </a>
      {%- endif -%}
      <a href="{{ routes.cart_url }}" class="ch__icon ch__cart" aria-label="Warenkorb">
        <svg viewBox="0 0 24 24" width="22" height="22" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 7h13l-1.2 9.2a1.5 1.5 0 0 1-1.5 1.3H8.7a1.5 1.5 0 0 1-1.5-1.3L6 4H3"/><path d="M9 11a3 3 0 0 0 6 0"/></svg>
        <span class="cart-count-bubble{% if cart.item_count == 0 %} hidden{% endif %}">
          <span data-cart-count>{{ cart.item_count }}</span>
        </span>
      </a>
    </div>
  </div>

  <nav class="ch__mobile-nav" aria-label="Mobile Navigation" data-mobile-nav>
    <div class="ch__mobile-inner">
      {%- if menu != blank -%}
        {%- for link in menu.links -%}
          <a href="{{ link.url }}" class="ch__mobile-link">{{ link.title }}</a>
        {%- endfor -%}
      {%- else -%}
        <a href="#" class="ch__mobile-link">Shop</a>
        <a href="#" class="ch__mobile-link">Rezepte</a>
        <a href="#" class="ch__mobile-link">Über uns</a>
      {%- endif -%}
    </div>
  </nav>
</header>

<style>
  #ch-{{ section.id }} {
    --ch-text: #1f1f1f;
    --ch-border: #ececec;
    background: #fff;
    border-bottom: 1px solid var(--ch-border);
    font-family: 'Roboto', -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif;
  }
  #ch-{{ section.id }}.ch--sticky { position: sticky; top: 0; z-index: 50; }
  #ch-{{ section.id }} .ch__inner {
    max-width: 1280px; margin: 0 auto; padding: 18px 24px;
    display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; gap: 16px;
  }

  #ch-{{ section.id }} .ch__left { display: flex; align-items: center; }
  #ch-{{ section.id }} .ch__nav { display: flex; gap: 28px; }
  #ch-{{ section.id }} .ch__link {
    color: var(--ch-text); text-decoration: none; font-size: 15px; line-height: 1;
    transition: opacity .15s;
  }
  #ch-{{ section.id }} .ch__link:hover { opacity: .6; }
  #ch-{{ section.id }} .ch__burger { display: none; background: none; border: none; padding: 0; cursor: pointer; color: var(--ch-text); }

  #ch-{{ section.id }} .ch__center { display: flex; justify-content: center; }
  #ch-{{ section.id }} .ch__logo { display: inline-flex; align-items: center; text-decoration: none; }
  #ch-{{ section.id }} .ch__logo img { display: block; }
  #ch-{{ section.id }} .ch__logo-text { font-size: 22px; font-weight: 500; color: var(--ch-text); white-space: nowrap; }

  #ch-{{ section.id }} .ch__right { display: flex; align-items: center; justify-content: flex-end; gap: 18px; }
  #ch-{{ section.id }} .ch__icon { color: var(--ch-text); position: relative; display: inline-flex; }
  #ch-{{ section.id }} .ch__icon:hover { opacity: .6; }
  #ch-{{ section.id }} .ch__cart svg { width: 27px; height: 27px; }
  #ch-{{ section.id }} .ch__cart .cart-count-bubble {
    position: absolute; top: -3px; right: -3px;
    background: var(--ch-text); color: #fff; font-size: 10px; line-height: 1;
    min-width: 15px; height: 15px; border-radius: 8px;
    display: inline-flex; align-items: center; justify-content: center; padding: 0 4px;
  }
  #ch-{{ section.id }} .ch__cart .cart-count-bubble.hidden { display: none; }

  #ch-{{ section.id }} .ch__mobile-nav {
    display: grid; grid-template-rows: 0fr;
    transition: grid-template-rows .32s ease;
  }
  #ch-{{ section.id }} .ch__mobile-nav.is-open { grid-template-rows: 1fr; }
  #ch-{{ section.id }} .ch__mobile-inner {
    overflow: hidden; min-height: 0;
    opacity: 0; transition: opacity .25s ease;
    padding: 0 24px; display: flex; flex-direction: column;
  }
  #ch-{{ section.id }} .ch__mobile-nav.is-open .ch__mobile-inner {
    opacity: 1; border-top: 1px solid var(--ch-border);
  }
  #ch-{{ section.id }} .ch__mobile-link { color: var(--ch-text); text-decoration: none; padding: 14px 0; font-size: 16px; border-bottom: 1px solid var(--ch-border); }
  #ch-{{ section.id }} .ch__mobile-link:last-child { border-bottom: none; }

  @media (max-width: 749px) {
    #ch-{{ section.id }} .ch__inner { padding: 14px 18px; }
    #ch-{{ section.id }} .ch__nav { display: none; }
    #ch-{{ section.id }} .ch__burger { display: inline-flex; }
    #ch-{{ section.id }} .ch__right { gap: 0; }
    #ch-{{ section.id }} .ch__right .ch__icon:not(.ch__cart) { display: none; }
    #ch-{{ section.id }} .ch__cart svg { width: 28px; height: 28px; }
    #ch-{{ section.id }} .ch__logo-text { font-size: 18px; }
  }
  @media (min-width: 750px) {
    #ch-{{ section.id }} .ch__mobile-nav { display: none !important; }
    #ch-{{ section.id }} .ch__cart { top: 1px; }
  }
</style>

<script>
  (function () {
    var root = document.getElementById('ch-{{ section.id }}');
    if (!root) return;
    var burger = root.querySelector('[data-burger]');
    var mobileNav = root.querySelector('[data-mobile-nav]');
    if (burger && mobileNav) {
      burger.addEventListener('click', function () {
        var willOpen = !mobileNav.classList.contains('is-open');
        mobileNav.classList.toggle('is-open', willOpen);
        burger.setAttribute('aria-expanded', willOpen ? 'true' : 'false');
      });
    }
  })();
</script>

{% schema %}
{
  "name": "Custom Header",
  "settings": [
    { "type": "image_picker", "id": "logo", "label": "Logo" },
    { "type": "range", "id": "logo_width", "min": 24, "max": 120, "step": 2, "unit": "px", "label": "Logo-Breite", "default": 44 },
    { "type": "link_list", "id": "menu", "label": "Menü", "default": "main-menu" },
    { "type": "checkbox", "id": "show_account", "label": "Account-Icon anzeigen", "default": true },
    { "type": "checkbox", "id": "enable_sticky", "label": "Header beim Scrollen fixieren", "default": false }
  ]
}
{% endschema %}
